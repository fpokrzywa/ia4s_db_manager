# DATABASE_URL — seeds the FIRST server into the registry on the initial
# `dbmanager init-auth` run. Afterwards the in-app server registry is the
# source of truth and this variable is unused (optional once the registry is
# populated). Point it at the 'postgres' maintenance database.
DATABASE_URL=postgresql://admin:password@127.0.0.1:5432/postgres
# The 'common_data' database — holds the users, auth-audit (user_sessions),
# and server-registry (servers) tables. Created/seeded by `dbmanager init-auth`.
DATABASE_COMMON_DATA_URL=postgresql://admin:password@127.0.0.1:5432/common_data
# Random 32+ character string. Signs session cookies and derives the key that
# encrypts stored server passwords — changing it invalidates both.
APP_SECRET=change-me-to-a-long-random-string
